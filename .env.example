# ---- J&N Balloon Sculpting — environment variables ----
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.

# ---- Admin dashboard ----
# REQUIRED in production. The app refuses to start in production if this is
# unset (no default password). Use a long, random value.
ADMIN_PASSWORD=

# Secret used to sign admin session cookies. Optional but recommended: if unset,
# sessions are signed with a key derived from ADMIN_PASSWORD (so changing the
# password logs everyone out). Set a random 32+ char value to decouple them.
SESSION_SECRET=

# ---- Site URL ----
# REQUIRED in production. Used for canonical/OG metadata, sitemap/robots, and
# Stripe redirect URLs. Must be the full origin with NO trailing slash.
# Local dev: http://localhost:3000  ·  Production: https://your-domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Stripe (card payments) ----
# Leave blank to run in "pay on confirmation" mode.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# From the Stripe dashboard webhook endpoint (points at /api/stripe/webhook).
# Required for payments to be confirmed and recorded.
STRIPE_WEBHOOK_SECRET=

# ---- Booking notifications ----
# Where new-booking emails go.
BOOKING_NOTIFY_EMAIL=hello@jnballoons.co.uk
# Set to send real emails via Resend (https://resend.com). If unset, bookings
# are logged to the server console instead.
RESEND_API_KEY=
RESEND_FROM=J&N Bookings <bookings@jnballoons.co.uk>

# ---- Database (REQUIRED for durable production data) ----
# When any of these is set the app uses Postgres (lib/store/postgresRepository)
# instead of the ephemeral JSON file store, so orders/bookings/content survive
# across serverless instances. Provision "Postgres" (Neon) from the Vercel
# Marketplace — it injects these automatically — or paste any Postgres URL
# (Supabase, RDS, etc.). Use the POOLED connection string on serverless.
DATABASE_URL=
# POSTGRES_URL=            # alternative name (Vercel/Neon also set this)
# POSTGRES_PRISMA_URL=     # alternative name

# ---- Bookings safety gate ----
# The site only takes REAL card bookings when a database is configured AND this
# is exactly "true". Leave blank/false until you've verified persistence on the
# live deployment (see docs/PRODUCTION-DB.md). Until then it runs enquiry-only.
BOOKINGS_LIVE=
