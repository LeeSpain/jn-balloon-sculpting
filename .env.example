# ---- J&N Balloon Sculpting — environment variables ----
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.

# Admin dashboard login (used until a real DB/auth is wired in)
ADMIN_PASSWORD=change-me

# Stripe (server-side). Leave blank to run in "pay on confirmation" mode.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Where Stripe should send customers after checkout (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Notifications — where new booking emails go (wired when email provider added)
BOOKING_NOTIFY_EMAIL=hello@jnballoons.co.uk

# ---- Database (swap the stub for a real DB before launch) ----
# When ready, add e.g. Supabase or Vercel Postgres credentials here:
# DATABASE_URL=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
